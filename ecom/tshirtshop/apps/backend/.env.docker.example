# Copy to apps/backend/.env.docker (gitignored). docker-compose.yml uses env_file: apps/backend/.env.docker

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@postgres:5432/ecommerenceshop

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
UI_URL=https://localhost:3001
NODE_ENV=production

# ─── Better Auth ──────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=generate_64_char_hex_or_random_string

# ─── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=you@yourdomain.com

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=

# ─── Encryption ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=64_char_hex_32_bytes
BLIND_INDEX_SECRET=long_random_string

# ─── Google reCAPTCHA ─────────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=
NEXT_PUBLIC_RECAPTCHA_SITEKEY=

# ─── OAuth — Google ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# ─── OAuth — Facebook ─────────────────────────────────────────────────────────
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ─── HTTPS ────────────────────────────────────────────────────────────────────
USE_HTTPS=1

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Seeder (docker-seed-all.mjs) ───────────────────────────────────────────
# Admin user created automatically on first seed
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=admin12345678
ADMIN_NAME=Admin
