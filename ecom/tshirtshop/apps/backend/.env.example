# Database 
DATABASE_URL=postgresql://user:password@localhost:5432/tshirtshop

# Server ─
PORT=3000
UI_URL=http://localhost:3001
NODE_ENV=development
# USE_HTTPS=1 — enable HTTPS (requires certs from: node scripts/generate-tls-cert.mjs)

# Better Auth 
# Better Auth uses BETTER_AUTH_SECRET for signing cookies/tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
BETTER_AUTH_SECRET=your-better-auth-secret-change-me

# At-rest encryption (SEC — email & name encryption)
# 64-char hex key for AES-256-GCM encryption of email/name.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_string_here
# Long random secret for HMAC-SHA256 blind index (deterministic email lookups).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BLIND_INDEX_SECRET=another_long_random_secret_here

# Resend (email) 
RESEND_API_KEY=re_2311Q8HK_FM2X5SSM1xAUE4A5h5QrKLzr
EMAIL_FROM=Darkloom <noreply@lugriv.com>
# CONTACT_EMAIL=support@example.com — where contact form submissions are sent (defaults to EMAIL_FROM)

# Google reCAPTCHA ─
# Required in production (RECAPTCHA_REQUIRED=1). In dev, optional — sign-up works without when keys unset.
RECAPTCHA_SECRET_KEY=your-google-recaptcha-secret-key
NEXT_PUBLIC_RECAPTCHA_SITEKEY=your-google-recaptcha-site-key
# RECAPTCHA_REQUIRED=1 — enforce CAPTCHA on sign-up in production (AUTH-008)

# OAuth — Google 
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — Facebook 
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Stripe (PAY-001) — test keys for sandbox. Get from Stripe Dashboard → Developers → API keys (Test mode)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# E2E / local dev: skip Stripe Checkout session creation (guest checkout → /checkout/confirmation only).
# Playwright also injects this when it starts `npm run dev`. Ignored when NODE_ENV=production.
# E2E_SKIP_STRIPE_CHECKOUT=1

# Redis — used by BullMQ for the payment-events message queue
# Docker: docker run -d -p 6379:6379 redis:7-alpine
REDIS_URL=redis://localhost:6379
